<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barcode_generate_wizard" model="ir.ui.view">
        <field name="name">barcode.generate.wizard.form</field>
        <field name="model">barcode.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Barcode">
                <group>
                    <field name="overwrite_existing"/>
                    <!-- <div class="o_form_label">Generate Barcode for selected products?</div> -->
                </group>

                <footer>
                    <button name="action_generate" type="object" string="Generate" class="btn-primary" />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_barcode_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Barcode</field>
        <field name="res_model">barcode.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>