<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_barcode" model="ir.ui.view">
        <field name="name">res.config.settings.barcode</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//block[@id='user_default_rights']" position="after">

                <block title="Barcode Generator Configuration">

                    <setting string="Generate Product Barcode On Product Create?">
                        <field name="auto_generate_barcode"/>
                    </setting>

                    <setting string="Barcode Type">
                        <field name="barcode_type"/>
                    </setting>

                </block>

            </xpath>

        </field>
    </record>

</odoo>